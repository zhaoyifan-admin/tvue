{
  "compilerOptions": {
    "target": "ES2018",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["ES2018", "DOM", "DOM.Iterable"],
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "noEmit": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "src/*": ["src/*"],
      "core/*": ["src/core/*"],
      "locale/*": ["src/locale/*"],
      "global/*": ["src/global/*"],
      "plugin/*": ["src/plugin/*"],
      "utils/*": ["src/utils/*"],
      "mixins/*": ["packages/mixins/*"],
      "common/*": ["packages/core/*"],
      "packages/*": ["packages/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "types/**/*.d.ts"
  ],
  "exclude": ["node_modules", "lib", "examples"]
}
